# --- Server ---
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/approval_platform?schema=public"

# --- Redis / BullMQ ---
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# --- Email (SMTP) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Social Approval Platform <no-reply@example.com>"

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Cookies ---
COOKIE_SECRET="change-me-cookie-secret"

# --- Social Platforms (OAuth) ---
SOCIAL_CREDS_KEY="generate-a-strong-32-byte-key-here"
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
